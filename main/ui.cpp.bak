    lv_obj_set_style_bg_color(s3a_detail_card, lv_color_hex(0x151C30), 0);
    lv_obj_set_style_bg_opa(s3a_detail_card, LV_OPA_80, 0);
    lv_obj_set_style_border_color(s3a_detail_card, lv_color_hex(0x4AA3FF40), 0);
    lv_obj_set_style_border_width(s3a_detail_card, 1, 0);
    lv_obj_set_style_radius(s3a_detail_card, 18, 0);

    node1_voc_label = lv_label_create(s3a_detail_card);
    lv_label_set_text(node1_voc_label, "VOC:-- ppm");
    lv_obj_set_style_text_font(node1_voc_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node1_voc_label, COLOR_TEXT, 0);
    lv_obj_align(node1_voc_label, LV_ALIGN_TOP_LEFT, 30, 20);

    node1_co2_label = lv_label_create(s3a_detail_card);
    lv_label_set_text(node1_co2_label, "CO2:-- ppm");
    lv_obj_set_style_text_font(node1_co2_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node1_co2_label, COLOR_TEXT, 0);
    lv_obj_align(node1_co2_label, LV_ALIGN_TOP_LEFT, 30, 68);

    node1_odor_label = lv_label_create(s3a_detail_card);
    lv_label_set_text(node1_odor_label, "Odor:-- ppm");
    lv_obj_set_style_text_font(node1_odor_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node1_odor_label, COLOR_TEXT, 0);
    lv_obj_align(node1_odor_label, LV_ALIGN_TOP_LEFT, 30, 116);

    node1_hcho_label = lv_label_create(s3a_detail_card);
    lv_label_set_text(node1_hcho_label, "HCHO:-- ppm");
    lv_obj_set_style_text_font(node1_hcho_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node1_hcho_label, COLOR_TEXT, 0);
    lv_obj_align(node1_hcho_label, LV_ALIGN_TOP_LEFT, 310, 20);

    node1_co_label = lv_label_create(s3a_detail_card);
    lv_label_set_text(node1_co_label, "CO:-- ppm");
    lv_obj_set_style_text_font(node1_co_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node1_co_label, COLOR_TEXT, 0);
    lv_obj_align(node1_co_label, LV_ALIGN_TOP_LEFT, 310, 68);

    node1_pred_label = lv_label_create(s3a_detail_card);
    lv_label_set_text(node1_pred_label, "Pred:--");
    lv_obj_set_style_text_font(node1_pred_label, &lv_font_montserrat_24, 0);
    lv_obj_set_style_text_color(node1_pred_label, lv_color_hex(0x39D98A), 0);
    lv_obj_align(node1_pred_label, LV_ALIGN_TOP_LEFT, 310, 116);

    /* UV Control Panel */
    s_warmup_lbl = lv_label_create(s3a_detail_card);
    lv_label_set_text(s_warmup_lbl, "");
    lv_obj_set_style_text_color(s_warmup_lbl, lv_color_hex(0xFFB84D), 0);
    lv_obj_set_style_text_font(s_warmup_lbl, &lv_font_montserrat_20, 0);
    lv_obj_align(s_warmup_lbl, LV_ALIGN_TOP_MID, 0, 180);
    lv_obj_add_flag(s_warmup_lbl, LV_OBJ_FLAG_HIDDEN);

    s_uv_btn = lv_btn_create(s3a_detail_card);
    lv_obj_set_size(s_uv_btn, 130, 44);
    lv_obj_align(s_uv_btn, LV_ALIGN_BOTTOM_LEFT, 30, -12);
    lv_obj_set_style_radius(s_uv_btn, 22, 0);
    lv_obj_set_style_bg_color(s_uv_btn, lv_color_hex(0x6655FF), 0);
    s_uv_lbl = lv_label_create(s_uv_btn);
    lv_label_set_text(s_uv_lbl, "UV OFF");
    lv_obj_set_style_text_color(s_uv_lbl, lv_color_hex(0xFFFFFF), 0);
    lv_obj_set_style_text_font(s_uv_lbl, &lv_font_montserrat_18, 0);
    lv_obj_center(s_uv_lbl);
    lv_obj_add_event_cb(s_uv_btn, [](lv_event_t * e) {
        bool cur_uv = false;
        if (s_udp_data_mutex && xSemaphoreTake(s_udp_data_mutex, pdMS_TO_TICKS(10)) == pdTRUE) {
            cur_uv = s_udp_node1.uv;
            xSemaphoreGive(s_udp_data_mutex);
        }
        bool new_uv = !cur_uv;
        uart_receiver_send(new_uv ? "uv_on" : "uv_off");
        ui_set_uv(new_uv);
    }, LV_EVENT_CLICKED, NULL);

    /* Dur -30s */
    lv_obj_t * uv_dur_minus_btn = lv_btn_create(s3a_detail_card);
    lv_obj_set_size(uv_dur_minus_btn, 100, 44);
    lv_obj_align(uv_dur_minus_btn, LV_ALIGN_BOTTOM_LEFT, 170, -12);
    lv_obj_set_style_radius(uv_dur_minus_btn, 22, 0);
    lv_obj_set_style_bg_color(uv_dur_minus_btn, lv_color_hex(0x2A3A5A), 0);
    lv_obj_t * uv_dur_minus_lbl = lv_label_create(uv_dur_minus_btn);
    lv_label_set_text(uv_dur_minus_lbl, "Dur -30s");
    lv_obj_set_style_text_color(uv_dur_minus_lbl, lv_color_hex(0xFFFFFF), 0);
    lv_obj_set_style_text_font(uv_dur_minus_lbl, &lv_font_montserrat_18, 0);
    lv_obj_center(uv_dur_minus_lbl);
    lv_obj_add_event_cb(uv_dur_minus_btn, [](lv_event_t * e) {
        int new_dur = s_uv_dur_setting - 30;
        if (new_dur < 30) new_dur = 30; /* minimum 30s */
        s_uv_dur_setting = new_dur;
        /* Update local data so timer callback doesn't overwrite */
        if (s_udp_data_mutex && xSemaphoreTake(s_udp_data_mutex, pdMS_TO_TICKS(10)) == pdTRUE) {
            s_udp_node1.uv_dur = new_dur;
            xSemaphoreGive(s_udp_data_mutex);
        }
        /* Update UI immediately */
        if (s_uv_dur_lbl) lv_label_set_text_fmt(s_uv_dur_lbl, "UV dur: %ds", new_dur);
        /* Send command to C6 (value in minutes) */
        int minutes = new_dur / 60;
        int remainder = new_dur % 60;
        char cmd[32];
        if (remainder == 0) {
            snprintf(cmd, sizeof(cmd), "uv_dur %d", minutes);
        } else {
            snprintf(cmd, sizeof(cmd), "uv_dur %d.%d", minutes, remainder * 10 / 60);
        }
        ESP_LOGI("UV", "Dur -30s: -> %ds, cmd=%s", new_dur, cmd);
        uart_receiver_send(cmd);
    }, LV_EVENT_CLICKED, NULL);

    /* Dur +30s */
    lv_obj_t * uv_dur_plus_btn = lv_btn_create(s3a_detail_card);
    lv_obj_set_size(uv_dur_plus_btn, 100, 44);
    lv_obj_align(uv_dur_plus_btn, LV_ALIGN_BOTTOM_LEFT, 280, -12);
    lv_obj_set_style_radius(uv_dur_plus_btn, 22, 0);
    lv_obj_set_style_bg_color(uv_dur_plus_btn, lv_color_hex(0x2A3A5A), 0);
    lv_obj_t * uv_dur_plus_lbl = lv_label_create(uv_dur_plus_btn);
    lv_label_set_text(uv_dur_plus_lbl, "Dur +30s");
    lv_obj_set_style_text_color(uv_dur_plus_lbl, lv_color_hex(0xFFFFFF), 0);
    lv_obj_set_style_text_font(uv_dur_plus_lbl, &lv_font_montserrat_18, 0);
    lv_obj_center(uv_dur_plus_lbl);
    lv_obj_add_event_cb(uv_dur_plus_btn, [](lv_event_t * e) {
        int new_dur = s_uv_dur_setting + 30;
        if (new_dur > 600) new_dur = 600; /* max 10 minutes */
        s_uv_dur_setting = new_dur;
        /* Update local data so timer callback doesn't overwrite */
        if (s_udp_data_mutex && xSemaphoreTake(s_udp_data_mutex, pdMS_TO_TICKS(10)) == pdTRUE) {
            s_udp_node1.uv_dur = new_dur;
            xSemaphoreGive(s_udp_data_mutex);
        }
        /* Update UI immediately */
        if (s_uv_dur_lbl) lv_label_set_text_fmt(s_uv_dur_lbl, "UV dur: %ds", new_dur);
        /* Send command to C6 (value in minutes) */
        int minutes = new_dur / 60;
        int remainder = new_dur % 60;
        char cmd[32];
        if (remainder == 0) {
            snprintf(cmd, sizeof(cmd), "uv_dur %d", minutes);
        } else {
            snprintf(cmd, sizeof(cmd), "uv_dur %d.%d", minutes, remainder * 10 / 60);
        }
        ESP_LOGI("UV", "Dur +30s: -> %ds, cmd=%s", new_dur, cmd);
        uart_receiver_send(cmd);
    }, LV_EVENT_CLICKED, NULL);

    s_uv_remain_lbl = lv_label_create(s3a_detail_card);
    lv_label_set_text(s_uv_remain_lbl, "UV remain: --");
    lv_obj_set_style_text_color(s_uv_remain_lbl, lv_color_hex(0x91A0B8), 0);
    lv_obj_set_style_text_font(s_uv_remain_lbl, &lv_font_montserrat_16, 0);
    lv_obj_align(s_uv_remain_lbl, LV_ALIGN_BOTTOM_LEFT, 30, -60);

    s_uv_dur_lbl = lv_label_create(s3a_detail_card);
    lv_label_set_text(s_uv_dur_lbl, "UV dur: --s");
    lv_obj_set_style_text_color(s_uv_dur_lbl, lv_color_hex(0x91A0B8), 0);
    lv_obj_set_style_text_font(s_uv_dur_lbl, &lv_font_montserrat_16, 0);
    lv_obj_align(s_uv_dur_lbl, LV_ALIGN_BOTTOM_LEFT, 180, -60);

    lv_obj_t * skip_warmup_btn = lv_btn_create(s3a_detail_card);
    lv_obj_set_size(skip_warmup_btn, 120, 44);
    lv_obj_align(skip_warmup_btn, LV_ALIGN_BOTTOM_LEFT, 460, -12);
    lv_obj_set_style_radius(skip_warmup_btn, 22, 0);
    lv_obj_set_style_bg_color(skip_warmup_btn, lv_color_hex(0xFF5533), 0);
    lv_obj_t * skip_warmup_lbl = lv_label_create(skip_warmup_btn);
    lv_label_set_text(skip_warmup_lbl, "Skip Warmup");
    lv_obj_set_style_text_color(skip_warmup_lbl, lv_color_hex(0xFFFFFF), 0);
    lv_obj_set_style_text_font(skip_warmup_lbl, &lv_font_montserrat_16, 0);
    lv_obj_center(skip_warmup_lbl);
    lv_obj_add_event_cb(skip_warmup_btn, [](lv_event_t * e) {
        uart_receiver_send("skip warmup");
        uart_receiver_set_warmup_remaining(0);
    }, LV_EVENT_CLICKED, NULL);

    /* S3-B Detail Screen */
    scr_s3b = lv_obj_create(NULL);
    apply_no_shadow(scr_s3b);
    lv_obj_set_style_bg_color(scr_s3b, lv_color_hex(0x0B1020), 0);
    lv_obj_set_style_bg_opa(scr_s3b, LV_OPA_COVER, 0);

    lv_obj_t * s3b_back = lv_btn_create(scr_s3b);
    lv_obj_set_pos(s3b_back, 10, 10);
    lv_obj_set_size(s3b_back, 80, 40);
    lv_obj_set_style_bg_color(s3b_back, lv_color_hex(0x444444), 0);
    lv_obj_set_style_radius(s3b_back, 5, 0);
    lv_obj_t * s3b_back_lbl = lv_label_create(s3b_back);
    lv_label_set_text(s3b_back_lbl, "< Back");
    lv_obj_set_style_text_color(s3b_back_lbl, lv_color_hex(0xFFFFFF), 0);
    lv_obj_center(s3b_back_lbl);
    lv_obj_add_event_cb(s3b_back, [](lv_event_t * e){ lv_screen_load(scr_main); }, LV_EVENT_CLICKED, NULL);

    lv_obj_t * s3b_title = lv_label_create(scr_s3b);
    lv_label_set_text(s3b_title, "S3-B Sensor Data");
    lv_obj_set_style_text_font(s3b_title, &lv_font_montserrat_24, 0);
    lv_obj_set_style_text_color(s3b_title, lv_color_hex(0x4AA3FF), 0);
    lv_obj_align(s3b_title, LV_ALIGN_TOP_MID, 0, 14);

    lv_obj_t * s3b_detail_card = lv_obj_create(scr_s3b);
    apply_no_shadow(s3b_detail_card);
    lv_obj_set_size(s3b_detail_card, 600, 320);
    lv_obj_align(s3b_detail_card, LV_ALIGN_CENTER, 0, 20);
    lv_obj_set_style_bg_color(s3b_detail_card, lv_color_hex(0x151C30), 0);
    lv_obj_set_style_bg_opa(s3b_detail_card, LV_OPA_80, 0);
    lv_obj_set_style_border_color(s3b_detail_card, lv_color_hex(0x4AA3FF40), 0);
    lv_obj_set_style_border_width(s3b_detail_card, 1, 0);
    lv_obj_set_style_radius(s3b_detail_card, 18, 0);

    node2_voc_label = lv_label_create(s3b_detail_card);
    lv_label_set_text(node2_voc_label, "VOC:-- ppm");
    lv_obj_set_style_text_font(node2_voc_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node2_voc_label, COLOR_TEXT, 0);
    lv_obj_align(node2_voc_label, LV_ALIGN_TOP_LEFT, 30, 20);

    node2_co2_label = lv_label_create(s3b_detail_card);
    lv_label_set_text(node2_co2_label, "CO2:-- ppm");
    lv_obj_set_style_text_font(node2_co2_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node2_co2_label, COLOR_TEXT, 0);
    lv_obj_align(node2_co2_label, LV_ALIGN_TOP_LEFT, 30, 68);

    node2_odor_label = lv_label_create(s3b_detail_card);
    lv_label_set_text(node2_odor_label, "Odor:-- ppm");
    lv_obj_set_style_text_font(node2_odor_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node2_odor_label, COLOR_TEXT, 0);
    lv_obj_align(node2_odor_label, LV_ALIGN_TOP_LEFT, 30, 116);

    node2_hcho_label = lv_label_create(s3b_detail_card);
    lv_label_set_text(node2_hcho_label, "HCHO:-- ppm");
    lv_obj_set_style_text_font(node2_hcho_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node2_hcho_label, COLOR_TEXT, 0);
    lv_obj_align(node2_hcho_label, LV_ALIGN_TOP_LEFT, 310, 20);

    node2_co_label = lv_label_create(s3b_detail_card);
    lv_label_set_text(node2_co_label, "CO:-- ppm");
    lv_obj_set_style_text_font(node2_co_label, &lv_font_montserrat_20, 0);
    lv_obj_set_style_text_color(node2_co_label, COLOR_TEXT, 0);
    lv_obj_align(node2_co_label, LV_ALIGN_TOP_LEFT, 310, 68);

    node2_pred_label = lv_label_create(s3b_detail_card);
    lv_label_set_text(node2_pred_label, "Pred:--");
    lv_obj_set_style_text_font(node2_pred_label, &lv_font_montserrat_24, 0);
    lv_obj_set_style_text_color(node2_pred_label, lv_color_hex(0x39D98A), 0);
    lv_obj_align(node2_pred_label, LV_ALIGN_TOP_LEFT, 310, 116);

    /* Reload startup wallpaper right before showing screen (slot 0 — no longer shared) */
    if (sd_card_bg_is_ready() && s_current_startup_wallpaper_path[0]) {
        const lv_image_dsc_t *img = sd_card_bg_load_jpeg_slot(s_current_startup_wallpaper_path, 0);
        if (img && s_startup_wallpaper_img) {
            lv_image_set_src(s_startup_wallpaper_img, img);
            ESP_LOGI("UI", "Startup wallpaper refreshed for display");
        }
    }

    lv_screen_load(scr_startup);
}

/* Web camera: JPEG pre-encoded in camera callback, HTTP handler just reads it */

bool ui_is_camera_available(void) {
    return web_jpeg_available();
}

bool ui_get_camera_frame(uint8_t **buf, uint32_t *w, uint32_t *h, size_t *len) {
    return web_jpeg_get_frame(buf, w, h, len);
}
